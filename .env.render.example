# Production environment for free hosting (Render + Neon)
# Copy values into Render Dashboard → Environment

APP_NAME=MENSWEAR
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.onrender.com
APP_KEY=                          # Render can auto-generate
APP_ADMIN_URL=admin

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Neon PostgreSQL (https://neon.tech — free tier, no 30-day expiry)
DB_CONNECTION=pgsql
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Or set individually:
# DB_HOST=ep-xxx.region.aws.neon.tech
# DB_PORT=5432
# DB_DATABASE=neondb
# DB_USERNAME=your_user
# DB_PASSWORD=your_password
# DB_SSLMODE=require

SESSION_DRIVER=database
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

# Set true ONLY on first deploy, then change to false
RUN_SEED=true

PORT=10000
